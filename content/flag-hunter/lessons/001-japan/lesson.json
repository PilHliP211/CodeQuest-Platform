              "portrait": null
            }
          ]
        }
      ]
    },
    "conceptIntro": {
      "concept": "sequences",
      "title": "Sequences Run in Order",
      "body": "A sequence is a set of instructions that runs one step at a time from top to bottom.",
      "example": "moveEast()\nmoveEast()"
    },
    "challenge": {
      "prompt": "Build a sequence that moves toward Japan.",
      "targetPath": ["001-japan"],
      "startNode": "home-base",
      "availableBlocks": ["moveEast", "moveWest", "moveNorth", "moveSouth"],
      "solution": {
        "code": "moveEast()"
      },
      "hints": [
        { "afterAttempts": 1, "text": "Japan is east from the starting point. Try moveEast()." },
        { "afterAttempts": 3, "text": "Use a single moveEast() block, then run it." }
      ]
    },
    "outro": {
      "scenes": [
        {
          "dialogue": [
            {
              "speaker": "Guide",
              "text": "You made it to Japan. The flag pieces are missing, but the trail is still warm.",
              "portrait": null
            }
          ]
        }
      ]
    }
  },
  "phase2": {
