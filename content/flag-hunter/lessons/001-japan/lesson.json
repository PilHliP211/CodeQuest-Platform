        {
          "id": "white-background",
          "label": "White background",
          "icon": "assets/items/white-background.png"
        },
        { "id": "red-circle", "label": "Red circle", "icon": "assets/items/red-circle.png" }
      ],
      "solution": {
        "code": "searchArea()\ncollectItem()"
      },
      "hints": [
        { "afterAttempts": 1, "text": "Search first so you know what to collect." },
        { "afterAttempts": 3, "text": "Run searchArea(), then collectItem()." }
